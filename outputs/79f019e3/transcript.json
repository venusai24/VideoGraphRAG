        "start": "0:03:41.32",
        "end": "0:03:46.2"
      }
    ]
  },
  {
    "id": 36,
    "text": "Whoops.",
    "confidence": 0.4503,
    "speakerId": 1,
    "language": "en-US",
    "instances": [
      {
        "adjustedStart": "0:03:46.44",
        "adjustedEnd": "0:03:46.8",
        "start": "0:03:46.44",
        "end": "0:03:46.8"
      }
    ]
