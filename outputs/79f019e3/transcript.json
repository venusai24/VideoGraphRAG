        "adjustedEnd": "0:01:26.12",
        "start": "0:01:20",
        "end": "0:01:26.12"
      }
    ]
  },
  {
    "id": 16,
    "text": "Costs that were driven even higher by Russia's invasion of Ukraine in 2022 and the war that ensued.",
    "confidence": 0.8872,
    "speakerId": 1,
    "language": "en-US",
    "instances": [
      {
