        "adjustedEnd": "0:04:27.4",
        "start": "0:04:20.04",
        "end": "0:04:27.4"
      }
    ]
  },
  {
    "id": 43,
    "text": "The first skaters touched Santa Julia Arena ice on January 9th, when the still under construction arena hosted a handful of Italian Cup games to simulate Olympic Level 3 games a day ice use.",
    "confidence": 0.8696,
    "speakerId": 1,
    "language": "en-US",
    "instances": [
