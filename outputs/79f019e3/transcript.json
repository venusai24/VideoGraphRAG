        "adjustedEnd": "0:00:56.04",
        "start": "0:00:47",
        "end": "0:00:56.04"
      }
    ]
  },
  {
    "id": 10,
    "text": "To their credit, they did have a plan to get a hockey arena built.",
    "confidence": 0.8584,
    "speakerId": 1,
    "language": "en-US",
    "instances": [
      {
        "adjustedStart": "0:00:56.28",
        "adjustedEnd": "0:00:59.2",
        "start": "0:00:56.28",
        "end": "0:00:59.2"
      }
    ]
  },
  {
