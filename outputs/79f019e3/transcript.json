        "start": "0:03:32.76",
        "end": "0:03:41.2"
      }
    ]
  },
  {
    "id": 35,
    "text": "And also their owners weren't getting the hospitality suite on site they were promised, and also the arena wasn't done yet.",
    "confidence": 0.8918,
    "speakerId": 1,
    "language": "en-US",
    "instances": [
