    "instances": [
      {
        "adjustedStart": "0:02:05.08",
        "adjustedEnd": "0:02:06.4",
        "start": "0:02:05.08",
        "end": "0:02:06.4"
      }
    ]
  },
  {
    "id": 31,
    "text": "But then Constantinople Constantinoped out of there as part of a secret agreement with Britain, where Britain got control of Cyprus in exchange for backing the Ottomans.",
    "confidence": 0.8737,
