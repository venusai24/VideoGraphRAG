      }
    ]
  },
  {
    "id": 18,
    "text": "If you peek at its destinations, you can tell it's got a tantalizing set of international destinations, including Turkey, Turkey, Turkey, Turkey, Turkey, Turkey, Turkey, Turkey, Turkey, Turkey, and even Turkey.",
    "confidence": 0.8921,
    "speakerId": 1,
