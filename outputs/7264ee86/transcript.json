        "start": "0:01:09.24",
        "end": "0:01:16.96"
      }
    ]
  },
  {
    "id": 20,
    "text": "This is just where two different groups of people who really wanted Cyprus stopped fighting and it's actually the closest equivalent of the world to the much more iconic Korean DMZ.",
    "confidence": 0.8821,
    "speakerId": 1,
    "language": "en-US",
