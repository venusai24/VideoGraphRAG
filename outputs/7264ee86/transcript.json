        "start": "0:03:04.8",
        "end": "0:03:14.68"
      }
    ]
  },
  {
    "id": 44,
    "text": "And much like an eighth grade dance, you were forbidden from crossing to the other side and dancing with them, even if your crush was over there.",
    "confidence": 0.9524,
    "speakerId": 1,
    "language": "en-US",
    "instances": [
      {
