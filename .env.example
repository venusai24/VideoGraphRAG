# ==============================================================================
# VideoGraphRAG Environment Configuration
# Copy this file to .env and fill in your values
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# LLM API Keys
# You can provide multiple comma-separated keys for automatic round-robin failover
# ──────────────────────────────────────────────────────────────────────────────

# Required for Query Decomposition (Primary)
CEREBRAS_API_KEYS=your_cerebras_key_1,your_cerebras_key_2

# Required for Query Decomposition (Fallback if Cerebras fails)
GROQ_API_KEYS=your_groq_key_1,your_groq_key_2

# Required for Answer Generation
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2

# ──────────────────────────────────────────────────────────────────────────────
# Neo4j Aura Graph Databases
# ──────────────────────────────────────────────────────────────────────────────

# Clip Graph Database
NEO4J_CLIP_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_CLIP_USER=neo4j
NEO4J_CLIP_PASSWORD=your_clip_db_password

# Entity Graph Database
NEO4J_ENTITY_URI=neo4j+s://yyyyy.databases.neo4j.io
NEO4J_ENTITY_USER=neo4j
NEO4J_ENTITY_PASSWORD=your_entity_db_password

# ──────────────────────────────────────────────────────────────────────────────
# Azure Video Indexer (Required for ingestion pipeline)
# ──────────────────────────────────────────────────────────────────────────────

AZURE_VIDEO_INDEXER_API_KEY=your_azure_api_key
VIDEO_INDEXER_ACCOUNT_ID=your_account_id
VIDEO_INDEXER_LOCATION=trial
VIDEO_INDEXER_ACCOUNT_TYPE=trial
